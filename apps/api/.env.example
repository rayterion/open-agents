# Turso database (cloud)
# Get these from: turso db show <db-name> --url && turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# For local development, use a local SQLite file instead:
# TURSO_DATABASE_URL=file:./data/open-agents.db
# TURSO_AUTH_TOKEN=   (leave empty for local)

# Server
PORT=3000

